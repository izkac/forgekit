{
  "name": "forgekit",
  "version": "0.1.5",
  "private": true,
  "description": "Forgekit — portable agent skills monorepo (Forge workflow and more)",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "forgekit": "node packages/cli/bin/forgekit.mjs",
    "forge": "node packages/cli/bin/forge.mjs",
    "review": "node packages/cli/bin/review.mjs",
    "test": "npm run test --workspace=@izkac/forgekit",
    "lint": "npm run lint --workspace=@izkac/forgekit",
    "prepack": "npm run prepack --workspace=@izkac/forgekit",
    "install:link": "npm install && npm link --workspace=@izkac/forgekit"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
