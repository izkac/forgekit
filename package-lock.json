{
  "name": "forgekit",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "forgekit",
      "version": "0.1.0",
      "license": "MIT",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@forgekit/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "packages/cli": {
      "name": "@forgekit/cli",
      "version": "0.1.0",
      "license": "MIT",
      "bin": {
        "forge": "bin/forge.mjs",
        "forgekit": "bin/forgekit.mjs",
        "review": "bin/review.mjs"
      },
      "engines": {
        "node": ">=20"
      }
    }
  }
}
